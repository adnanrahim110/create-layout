{
  "name": "jsforge-cli",
  "version": "1.0.0",
  "description": "Universal JS scaffolding CLI for React, Next.js, Vue, Nuxt, Angular, and Express",
  "type": "module",
  "main": "bin/jsforge.js",
  "bin": {
    "jsforge": "bin/jsforge.js",
    "jf": "bin/jsforge.js"
  },
  "scripts": {
    "test": "echo \"No tests configured\" && exit 0",
    "publish:github": "node scripts/publish-github-package.cjs",
    "release:check-tag": "node scripts/verify-tag-version.cjs",
    "release:tag": "node scripts/release-tag.cjs",
    "release": "node scripts/release.cjs patch",
    "release:patch": "node scripts/release.cjs patch",
    "release:minor": "node scripts/release.cjs minor",
    "release:major": "node scripts/release.cjs major"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "scaffold",
    "generator",
    "react",
    "nextjs",
    "next",
    "vue",
    "nuxt",
    "angular",
    "express",
    "node",
    "javascript",
    "typescript",
    "boilerplate",
    "component",
    "hook",
    "feature"
  ],
  "author": "Adnan Rahim <adnankaka.786110@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adnanrahim110/jsforge-cli.git"
  },
  "bugs": {
    "url": "https://github.com/adnanrahim110/jsforge-cli/issues"
  },
  "homepage": "https://github.com/adnanrahim110/jsforge-cli#readme"
}
